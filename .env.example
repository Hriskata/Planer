# Copy to .env at the repo root. Read by docker-compose (env_file) at `docker compose up` time.

# Same generation approach as backend/.env.example:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

PORT=3000
DB_PATH=/app/backend/data/tasks.db
BACKUP_DIR=/app/backend/backups
UPLOADS_DIR=/app/backend/uploads

# Server timezone — task date/time have no timezone of their own (plain local
# wall-clock strings), so this must match where your users actually are or reminders
# fire at the wrong moment. Default: Europe/Sofia.
TZ=Europe/Sofia

# Cloudflare Tunnel token — see README "Cloudflare Tunnel" section for how to get one.
TUNNEL_TOKEN=

# Web Push (task reminders). Generate once with:
# node -e "console.log(require('web-push').generateVAPIDKeys())" (from backend/, after npm install)
# The frontend fetches VAPID_PUBLIC_KEY from GET /api/push/vapid-public-key at runtime,
# so it only needs to live here, not duplicated into a frontend env var.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
