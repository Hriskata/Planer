# Copy this file to .env and fill in the real values. .env is NOT committed to git.

PORT=3000

# Path to the SQLite file. In Docker this will point to a mounted volume (see Stage 4).
DB_PATH=./data/tasks.db

# Where `npm run backup` writes snapshots (see src/backup.js).
BACKUP_DIR=./backups

# Where uploaded task images are stored (see src/routes/uploads.js).
UPLOADS_DIR=./uploads

# A long random string — e.g. the output of: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Enable CORS only for the dev frontend server (Vite). Empty/unset = disabled (production).
CORS_ORIGIN=http://localhost:5173
